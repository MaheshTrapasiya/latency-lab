{
  "name": "latency-lab",
  "version": "1.2.1",
  "description": "Inject realistic network chaos into backend applications during local development and testing",
  "keywords": [
    "network",
    "chaos",
    "latency",
    "testing",
    "middleware",
    "express",
    "nextjs",
    "development",
    "simulation",
    "fault-injection",
    "fetch",
    "proxy",
    "cli",
    "undici"
  ],
  "author": "Mahesh Trapasiya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaheshTrapasiya/latency-lab.git"
  },
  "bugs": {
    "url": "https://github.com/MaheshTrapasiya/latency-lab/issues"
  },
  "homepage": "https://github.com/MaheshTrapasiya/latency-lab#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "latency-lab": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/express.d.ts",
        "default": "./dist/express.js"
      },
      "require": {
        "types": "./dist/express.d.cts",
        "default": "./dist/express.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      },
      "require": {
        "types": "./dist/next.d.cts",
        "default": "./dist/next.cjs"
      }
    },
    "./fastify": {
      "import": {
        "types": "./dist/fastify.d.ts",
        "default": "./dist/fastify.js"
      },
      "require": {
        "types": "./dist/fastify.d.cts",
        "default": "./dist/fastify.cjs"
      }
    },
    "./hono": {
      "import": {
        "types": "./dist/hono.d.ts",
        "default": "./dist/hono.js"
      },
      "require": {
        "types": "./dist/hono.d.cts",
        "default": "./dist/hono.cjs"
      }
    },
    "./fetch": {
      "import": {
        "types": "./dist/fetch.d.ts",
        "default": "./dist/fetch.js"
      },
      "require": {
        "types": "./dist/fetch.d.cts",
        "default": "./dist/fetch.cjs"
      }
    },
    "./presets": {
      "import": {
        "types": "./dist/presets.d.ts",
        "default": "./dist/presets.js"
      },
      "require": {
        "types": "./dist/presets.d.cts",
        "default": "./dist/presets.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:check": "tsc -p tsconfig.build.json --noEmit",
    "dev": "tsup --watch",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "test": "vitest run",
    "test:package": "npm run build && node test/package-smoke.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "version:release": "node scripts/bump-version.mjs",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "prepublishOnly": "npm run version:release && npm run build:check && npm run lint && npm run test && npm run test:package",
    "prepack": "npm run build",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.0.0",
    "fastify": "^5.8.5",
    "hono": "^4.12.26",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "vite": "^6.4.3"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "fastify": "^4.0.0 || ^5.0.0",
    "hono": "^4.0.0",
    "next": "^14.0.0 || ^15.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
